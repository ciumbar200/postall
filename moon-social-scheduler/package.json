{
  "name": "postall",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/check-dev-env.mjs && next dev --webpack -p 3000",
    "dev:turbo": "node scripts/check-dev-env.mjs && next dev --turbopack -p 3000",
    "dev:clean": "lsof -ti :3000 | xargs kill -9 2>/dev/null; rm -rf .next; node scripts/check-dev-env.mjs && next dev --webpack -p 3000",
    "dev:prod": "next start -p 3000",
    "dev:stable": "npm run build && next start -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/{app,components,hooks,lib,stores}/**/*.{ts,tsx}\" next.config.ts prisma.config.ts eslint.config.mjs",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.1",
    "@ai-sdk/openai": "^4.0.2",
    "@base-ui/react": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@next/env": "^16.2.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.1",
    "ai": "^7.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.15",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.16.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
