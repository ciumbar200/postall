# =============================================================================
# SOLO OPERADOR — no visible al usuario final del SaaS
# =============================================================================

# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Development fallback user/workspace (solo si NO hay Supabase Auth configurado)
DEV_USER_EMAIL=owner@postall.local
DEV_USER_NAME=Postall Owner
DEV_WORKSPACE_SLUG=
DEV_WORKSPACE_NAME=Postall Workspace
# UI local sin esperar PostgreSQL (evita pantalla colgada si DATABASE_URL falla)
DEV_SKIP_DATABASE=1

# Supabase Auth (login real). Si están presentes, se activa Supabase Auth + RLS.
NEXT_PUBLIC_SUPABASE_URL=https://tu-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cron (Vercel Cron / pg_cron). Vercel envía Authorization: Bearer $CRON_SECRET.
CRON_SECRET=

# Emails transaccionales (alertas de fallo, reconexión, renovación)
RESEND_API_KEY=
EMAIL_FROM=Postall <notifications@postall.app>

# Stripe billing (Checkout + Customer Portal + webhook)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREATOR=
STRIPE_PRICE_AGENT=
STRIPE_PRICE_AGENCY=

# =============================================================================
# IA INCLUIDA POR DEFECTO (hosted) — usuarios conectan sin configurar nada
# Agency puede override desde /dashboard/settings
# =============================================================================

# Proveedores: openai | anthropic | openrouter
AI_PROVIDER=openrouter
AI_MODEL=deepseek/deepseek-chat-v3-0324
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Postall

# Image Generation (fallback global para conector IMAGE_GEN)
OPENAI_IMAGE_MODEL=dall-e-3

# Cifrado de credenciales en DB (obligatorio en producción)
# También aceptado: CONNECTOR_ENCRYPTION_KEY (legacy)
CREDENTIAL_ENCRYPTION_KEY=
CONNECTOR_ENCRYPTION_KEY=

# =============================================================================
# APPS OAUTH COMPARTIDAS POSTALL (hosted default)
# Usuarios pulsan «Conectar» en /dashboard/accounts
# Agency puede usar apps propias desde el dashboard
# =============================================================================

# Canva Connect (fallback; usuarios Agent conectan vía OAuth en dashboard)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=
CANVA_DEFAULT_TEMPLATE=

# HeyGen / Fliki (fallback global; usuarios pegan keys en /dashboard/connectors)
HEYGEN_API_KEY=
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=
FLIKI_API_KEY=

# Database - Supabase (o PostgreSQL local)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.tu-project-ref.supabase.co:5432/postgres
DATABASE_POOLER_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media

# Instagram API with Instagram Login
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_AUTHORIZATION_URL=https://www.instagram.com/oauth/authorize
INSTAGRAM_TOKEN_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_GRAPH_API_BASE=https://graph.instagram.com
INSTAGRAM_GRAPH_API_VERSION=v25.0

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_AUTHORIZATION_URL=https://www.tiktok.com/v2/auth/authorize/
TIKTOK_TOKEN_URL=https://open.tiktokapis.com/v2/oauth/token/
TIKTOK_API_BASE=https://open.tiktokapis.com

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Facebook Pages
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# YouTube (Google OAuth)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Threads
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# Bluesky y Telegram: el usuario final conecta con token desde /dashboard/accounts
